{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/cron/balance-reset",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/v1/cron/daily-notifications",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/v1/cron/weekly-notifications",
      "schedule": "30 9 * * 1"
    }
  ]
}